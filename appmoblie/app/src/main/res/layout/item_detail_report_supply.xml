<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:minHeight="54dp"
    android:orientation="horizontal"
    android:paddingStart="8dp"
    android:paddingTop="8dp"
    android:paddingEnd="8dp"
    android:paddingBottom="8dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="38dp"
        android:layout_height="38dp"
        app:cardBackgroundColor="#F9FAFB"
        app:cardCornerRadius="10dp"
        app:cardElevation="0dp"
        app:strokeColor="#E5E7EB"
        app:strokeWidth="1dp">

        <ImageView
            android:id="@+id/ivSupplyItemIcon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/detail_report_supply_item_icon"
            android:padding="9dp"
            android:src="@drawable/ic_emergency_other"
            app:tint="#9CA3AF" />
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvSupplyItemName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:textColor="#1F2937"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSupplyItemMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:maxLines="1"
            android:textColor="#6B7280"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvSupplyItemQty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:textColor="#111827"
        android:textSize="13sp"
        android:textStyle="bold" />

</LinearLayout>
