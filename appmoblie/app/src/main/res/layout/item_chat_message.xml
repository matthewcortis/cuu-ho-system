<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layoutChatMessageRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <LinearLayout
        android:id="@+id/layoutChatMessageBubble"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_chat_message_incoming"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingTop="10dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/tvChatMessageSender"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/report_label_inactive"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvChatMessageText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:maxWidth="260dp"
            android:textColor="@color/report_text_primary"
            android:textSize="15sp"
            android:visibility="gone" />

        <FrameLayout
            android:id="@+id/layoutChatMessageMedia"
            android:layout_width="190dp"
            android:layout_height="190dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_report_surface_rounded"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:visibility="gone">

            <ImageView
                android:id="@+id/ivChatMessageMediaPreview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/report_attachment_media_preview"
                android:scaleType="centerCrop" />

            <ImageView
                android:id="@+id/ivChatMessageVideoOverlay"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="center"
                android:contentDescription="@string/report_attachment_video_badge"
                android:src="@drawable/ic_report_video_overlay"
                android:visibility="gone" />
        </FrameLayout>

        <LinearLayout
            android:id="@+id/layoutChatMessageAudio"
            android:layout_width="220dp"
            android:layout_height="46dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_report_audio_attachment"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:visibility="gone">

            <ImageButton
                android:id="@+id/btnChatMessageAudioPlay"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/report_attachment_audio_play"
                android:padding="6dp"
                android:src="@drawable/ic_report_audio_play"
                app:tint="@color/report_text_primary" />

            <TextView
                android:id="@+id/tvChatMessageAudioName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/report_text_primary"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvChatMessageTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/report_label_inactive"
            android:textSize="11sp" />
    </LinearLayout>

</LinearLayout>
