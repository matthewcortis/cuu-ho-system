<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_need_login_screen"
    android:clipToPadding="false"
    android:paddingStart="24dp"
    android:paddingTop="24dp"
    android:paddingEnd="24dp"
    android:paddingBottom="24dp"
    tools:context=".features.splash.ui.NotificationScreenFragment">

    <View
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="-110dp"
        android:background="@drawable/bg_need_login_decor_circle" />

    <View
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="36dp"
        android:layout_marginEnd="-72dp"
        android:background="@drawable/bg_need_login_decor_circle_soft" />

    <LinearLayout
        android:id="@+id/layout_notification_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="84dp"
            android:layout_height="84dp"
            app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="42dp"
            app:cardElevation="0dp"
            app:strokeColor="#22E02323"
            app:strokeWidth="1dp">

            <ImageView
                android:id="@+id/iv_notification_icon"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="center"
                android:contentDescription="@string/notification_icon_content_description"
                android:src="@drawable/ic_signup_lock"
                app:tint="@color/color_primary" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tv_notification_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:text="@string/need_login_title"
            android:textColor="@color/signup_text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_notification_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:lineSpacingExtra="3dp"
            android:text="@string/need_login_subtitle"
            android:textColor="@color/signup_text_secondary"
            android:textSize="15sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_notification_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_notification_primary_action"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/need_login_action"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="17sp"
            android:textStyle="bold"
            app:backgroundTint="@color/report_action_red"
            app:cornerRadius="20dp" />

        <TextView
            android:id="@+id/tv_notification_footer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/need_login_footer"
            android:textColor="@color/signup_text_secondary"
            android:textSize="13sp" />
    </LinearLayout>

</RelativeLayout>
