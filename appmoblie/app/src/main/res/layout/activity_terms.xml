<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/signup_background">

    <ScrollView
        android:id="@+id/terms_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/terms_bottom_section"
        android:fillViewport="true"
        android:overScrollMode="ifContentScrolls">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingTop="30dp"
            android:paddingEnd="22dp"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/terms_title"
                android:textColor="@color/color_primary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/terms_subtitle"
                android:textColor="@color/signup_text_secondary"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/terms_content"
                android:textColor="@color/signup_text_primary"
                android:textSize="14sp"
                android:lineSpacingExtra="3dp" />
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/terms_bottom_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingTop="12dp"
        android:paddingEnd="22dp"
        android:paddingBottom="20dp">

        <CheckBox
            android:id="@+id/cb_terms_agree"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/terms_agree_label"
            android:textColor="@color/signup_text_primary"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btn_terms_continue"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_login_button"
            android:backgroundTint="@color/report_action_red"
            android:enabled="false"
            android:text="@string/terms_continue"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="17sp"
            android:textStyle="bold" />
    </LinearLayout>

</RelativeLayout>
