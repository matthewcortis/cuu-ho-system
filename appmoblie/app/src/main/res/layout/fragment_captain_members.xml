<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/report_background">

    <TextView
        android:id="@+id/tvCaptainMembersTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="22dp"
        android:layout_marginTop="50dp"
        android:layout_marginEnd="22dp"
        android:text="@string/captain_members_title"
        android:textColor="@color/report_text_primary"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvCaptainMembersSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="22dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="22dp"
        android:text="@string/captain_members_subtitle"
        android:textColor="@color/report_location_text"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvCaptainMembersTitle" />

    <TextView
        android:id="@+id/tvCaptainMembersTeamName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="22dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_sos_filter_group"
        android:paddingStart="10dp"
        android:paddingTop="4dp"
        android:paddingEnd="10dp"
        android:paddingBottom="4dp"
        android:text="@string/captain_members_team_name_unknown"
        android:textColor="@color/report_location_text"
        android:textSize="12sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvCaptainMembersSubtitle" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCaptainMembers"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:paddingBottom="110dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvCaptainMembersTeamName" />

    <TextView
        android:id="@+id/tvCaptainMembersEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/captain_members_empty"
        android:textColor="@color/report_location_text"
        android:textSize="16sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/rvCaptainMembers"
        app:layout_constraintEnd_toEndOf="@id/rvCaptainMembers"
        app:layout_constraintStart_toStartOf="@id/rvCaptainMembers"
        app:layout_constraintTop_toTopOf="@id/rvCaptainMembers" />

</androidx.constraintlayout.widget.ConstraintLayout>
